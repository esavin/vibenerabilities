# Runtime artifacts generated when bootstrap.sh / run.sh are exercised in-place
# inside this tooling repo. None of these belong in the published repo.

# Generated by bootstrap.sh; records the local path/name of the project under analysis.
/config.json

# Generated/updated by run.sh during a walk (in-walk resume, counters, logs, verdicts).
/progress.json
/walk.log
/logs/
/verdicts/

# Disposable git worktrees created by the walker.
/.vibe-trees/

# An opencode install target if someone runs --setup with the repo as the workspace.
/.opencode/

# OS / editor noise
.DS_Store
*.swp
*~
